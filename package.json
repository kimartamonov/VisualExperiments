{
  "name": "visual-experiments",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit",
    "dev": "tsx watch src/server/index.ts",
    "prestart": "node scripts/build.mjs",
    "start": "node dist/server/index.js",
    "test": "node test/project-service.test.mjs && node test/navigation-runtime.test.mjs",
    "validate:m1": "node test/foundation-validation.mjs",
    "validate:m2": "node test/freeform-bootstrap-validation.mjs",
    "validate:m3": "node test/hierarchy-validation.mjs",
    "validate:m3:drilldown": "node test/drilldown-validation.mjs",
    "validate:m3:multidrilldown": "node test/multi-drilldown-validation.mjs",
    "validate:m3:navigation": "node test/navigation-context-validation.mjs",
    "validate:m3:spike": "node test/step-up-spike-validation.mjs",
    "validate:m3:stepup": "node test/step-up-validation.mjs",
    "validate:m4": "node test/typing-notation-validation.mjs",
    "validate:m4:typing": "node test/late-typing-validation.mjs",
    "validate:m4:notation": "node test/notation-extraction-validation.mjs",
    "validate:m4:typedmodel": "node test/typed-model-validation.mjs",
    "validate:m5:roundtrip": "node test/manual-save-roundtrip-validation.mjs",
    "validate:m5:recovery": "node test/error-recovery-validation.mjs",
    "validate:m5": "node test/persistence-recovery-validation.mjs",
    "validate:m5:demo": "node test/full-demo-acceptance-validation.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
